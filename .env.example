# Copia este archivo como .env y ajusta los valores.
# MySQL local sin contraseña:
DATABASE_URL=mysql+pymysql://root@localhost/tintwrap

# Con usuario y contraseña:
# DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/tintwrap

# SQLite (desarrollo):
# DATABASE_URL=sqlite:///./tintwrap.db

PORT=8030

# Orígenes extra para CORS (frontend en otro dominio). Separados por coma.
# CORS_ORIGINS=https://mi-app.web.app,https://www.midominio.com

# Autenticación del panel admin (JWT)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
JWT_EXPIRE_MINUTES=10080

# Usuario creado automáticamente si users está vacío
ADMIN_EMAIL=admin@tintwrap.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Administrador
