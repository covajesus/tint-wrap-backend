# Copia este archivo como .env y ajusta los valores.
# MySQL local sin contraseña:
DATABASE_URL=mysql+pymysql://root@localhost/tintwrap

# Con usuario y contraseña:
# DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/tintwrap

# SQLite (desarrollo):
# DATABASE_URL=sqlite:///./tintwrap.db

PORT=8030
