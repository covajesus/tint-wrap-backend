# Copia este archivo como .env y ajusta los valores.
#
# Desarrollo local (sin contraseña):
# DATABASE_URL=mysql+pymysql://root@localhost/tintwrap
#
# Producción (GoDaddy/VPS): NO uses root — error 1698 "Access denied for root@localhost".
# Crea un usuario MySQL con contraseña o usa el de cPanel:
# Sin espacios alrededor del = y sin comillas:
DATABASE_URL=mysql+pymysql://USUARIO:CONTRASEÑA@localhost:3306/tw
#
# Si la contraseña tiene caracteres especiales (@, #, /), codifícala en URL:
#   python -c "from urllib.parse import quote_plus; print(quote_plus('tu pass'))"

# SQLite (desarrollo):
# DATABASE_URL=sqlite:///./tintwrap.db

PORT=8030

# Orígenes extra para CORS (separados por coma)
# CORS_ORIGINS=https://otro-dominio.com

# Autenticación del panel admin (JWT)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
JWT_EXPIRE_MINUTES=10080

# Usuario creado automáticamente si users está vacío
ADMIN_EMAIL=admin@tintwrap.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Administrador
