[Unit]
Description=TintWrap API (uvicorn)
After=network.target mysql.service

[Service]
User=intrajis
Group=intrajis
WorkingDirectory=/var/www/api.tint-wrap.com/public_html
EnvironmentFile=/var/www/api.tint-wrap.com/public_html/.env
ExecStart=/var/www/api.tint-wrap.com/public_html/.tw/bin/uvicorn main:app --host 127.0.0.1 --port 8030
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
